# ================================
# Flask
# ================================
FLASK_ENV=development
SECRET_KEY=change-me-to-random-string
DEBUG=True

# ================================
# Database (SQLite)
# ================================
# Для SQLite: sqlite:///portfolio.db
# Для PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///portfolio.db

# ================================
# Mail (SMTP)
# ================================
# Примеры SMTP серверов:
#   Yandex:   smtp.yandex.ru (порт 465, SSL)
#   Mail.ru:  smtp.mail.ru (порт 465, SSL)
#   Gmail:    smtp.gmail.com (порт 587, TLS)
#   Rambler:  smtp.rambler.ru (порт 465, SSL)
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=your-email@yandex.ru
MAIL_PASSWORD=your-app-password
MAIL_OWNER_EMAIL=owner-email@example.com
MAIL_DEFAULT_SENDER=your-email@yandex.ru

# ================================
# AI (Ollama — локальный)
# ================================
# Установите Ollama: https://ollama.com/download
# Скачайте модель: ollama pull qwen2.5:3b
# Запустите: ollama serve
AI_ENABLED=True
AI_TIMEOUT=60
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MINUTES=60

# ================================
# Logging
# ================================
# Уровень: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ================================
# Data Directory
# ================================
DATA_DIR=data